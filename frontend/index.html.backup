                                            <div style="
                                                width: 8px;
                                                height: 8px;
                                                background: #10b981;
                                                border-radius: 50%;
                                                box-shadow: 0 0 8px #10b981;
                                            "></div>
                                            <span id="fed-node-id" style="color: #e5eef6; font-size: 12px; font-weight: 600;">-</span>
                                        </div>
                                        <div id="fed-node-status" style="color: #9fb0c3; font-size: 10px; margin-top: 4px;">Online</div>
                                    </div>

                                    <!-- Device -->
                                    <div style="background: rgba(0, 0, 0, 0.2); border-radius: 8px; padding: 12px;">
                                        <div style="color: #9fb0c3; font-size: 11px; margin-bottom: 4px;">Device</div>
                                        <div id="fed-device-info" style="color: #e5eef6; font-size: 12px; font-weight: 600;">-</div>
                                        <div id="fed-device-specs" style="color: #9fb0c3; font-size: 10px; margin-top: 4px;">-</div>
                                    </div>

                                    <!-- Model -->
                                    <div style="background: rgba(0, 0, 0, 0.2); border-radius: 8px; padding: 12px;">
                                        <div style="color: #9fb0c3; font-size: 11px; margin-bottom: 4px;">Model</div>
                                        <div id="fed-model-name" style="color: #e5eef6; font-size: 12px; font-weight: 600;">-</div>
                                        <div id="fed-model-info" style="color: #9fb0c3; font-size: 10px; margin-top: 4px;">-</div>
                                    </div>

                                    <!-- Signals Today -->
                                    <div style="background: rgba(0, 0, 0, 0.2); border-radius: 8px; padding: 12px;">
                                        <div style="color: #9fb0c3; font-size: 11px; margin-bottom: 4px;">Signals (today)</div>
                                        <div id="fed-signals-today" style="color: #8b5cf6; font-size: 20px; font-weight: 700;">-</div>
                                    </div>

                                    <!-- Peers -->
                                    <div style="background: rgba(0, 0, 0, 0.2); border-radius: 8px; padding: 12px;">
                                        <div style="color: #9fb0c3; font-size: 11px; margin-bottom: 4px;">Peers</div>
                                        <div style="display: flex; align-items: center; gap: 6px;">
                                            <span id="fed-peers-count" style="color: #e5eef6; font-size: 16px; font-weight: 700;">-</span>
                                            <span id="fed-peers-badge" style="
                                                background: #f59e0b;
                                                color: #fff;
                                                font-size: 9px;
                                                padding: 2px 6px;
                                                border-radius: 4px;
                                                font-weight: 600;
                                                display: none;
                                            ">Local only</span>
                                        </div>
                                        <div id="fed-port" style="color: #9fb0c3; font-size: 10px; margin-top: 4px;">Port: -</div>
                                    </div>

                                    <!-- Storage -->
                                    <div style="background: rgba(0, 0, 0, 0.2); border-radius: 8px; padding: 12px;">
                                        <div style="color: #9fb0c3; font-size: 11px; margin-bottom: 4px;">Storage</div>
                                        <div id="fed-storage" style="color: #e5eef6; font-size: 16px; font-weight: 700;">-</div>
                                        <div style="color: #9fb0c3; font-size: 10px; margin-top: 4px;">Traces + cache</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="content-page" id="settings-page">
            <div class="main-container">
                <div class="card" style="grid-column: 1 / -1; max-width: none;">
                    <div class="card-header">
                        <h2 class="card-title">⚙️ System Configuration</h2>
                    </div>
                    <div class="card-body" style="padding: 24px; overflow-y: auto;">

                        <!-- Section LLM Configuration -->
                        <div style="
                            background: rgba(99, 102, 241, 0.1);
                            border: 1px solid rgba(99, 102, 241, 0.3);
                            border-radius: 8px;
                            padding: 20px;
                            margin-bottom: 24px;
                        ">
                            <h4 style="color: #fff; margin: 0 0 16px 0; font-size: 18px; display: flex; align-items: center; gap: 8px;">
                                🤖 LLM Models Configuration
                            </h4>

                            <!-- LLM par défaut -->
                            <div style="
                                background: rgba(16, 185, 129, 0.1);
                                border: 1px solid rgba(16, 185, 129, 0.3);
                                border-radius: 6px;
                                padding: 12px;
                                margin-bottom: 16px;
                            ">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                    <span style="color: #10b981; font-weight: 600; font-size: 14px;">🔧 Default LLM (Local)</span>
                                    <span style="background: rgba(16, 185, 129, 0.2); color: #10b981; padding: 2px 8px; border-radius: 4px; font-size: 12px;">ACTIVE</span>
                                </div>
                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; font-size: 13px;">
                                    <div>
                                        <span style="color: #9ca3af;">Name:</span>
                                        <span style="color: #fff; margin-left: 8px;" id="default-llm-name">Loading...</span>
                                    </div>
                                    <div>
                                        <span style="color: #9ca3af;">Model:</span>
                                        <span style="color: #fff; margin-left: 8px;" id="default-llm-model">Loading...</span>
                                    </div>
                                    <div>
                                        <span style="color: #9ca3af;">URL:</span>
                                        <span style="color: #fff; margin-left: 8px;" id="default-llm-url">Loading...</span>
                                    </div>
                                    <div>
                                        <span style="color: #9ca3af;">Type:</span>
                                        <span style="color: #10b981; margin-left: 8px; font-weight: 600;" id="default-llm-type">Loading...</span>
                                    </div>
                                </div>
                            </div>

                            <!-- List of configured LLMs -->
                            <div style="margin-bottom: 16px;">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                                    <h5 style="color: #fff; margin: 0; font-size: 16px;">📋 Model Pool</h5>
                                    <button id="add-llm-btn" style="
                                        background: linear-gradient(135deg, #8b5cf6, #7c3aed);
                                        border: none;
                                        border-radius: 6px;
                                        color: #fff;
                                        padding: 6px 12px;
                                        cursor: pointer;
                                        font-size: 12px;
                                        font-weight: 600;
                                        transition: all 0.2s ease;
                                    ">+ Add LLM</button>
                                </div>

                                <div id="llm-pool-list" style="
                                    background: rgba(0, 0, 0, 0.2);
                                    border: 1px solid rgba(255, 255, 255, 0.1);
                                    border-radius: 8px;
                                    padding: 12px;
                                    max-height: 300px;
                                    overflow-y: auto;
                                ">
                                    <div style="text-align: center; color: #9ca3af; padding: 20px;">
                                        No additional LLM models configured
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Trading Simulations Configuration Section -->
                        <div style="
                            background: rgba(245, 158, 11, 0.1);
                            border: 1px solid rgba(245, 158, 11, 0.3);
                            border-radius: 8px;
                            padding: 20px;
                            margin-bottom: 24px;
                        ">
                            <h4 style="color: #fff; margin: 0 0 16px 0; font-size: 18px; display: flex; align-items: center; gap: 8px;">
                                💼 Trading Simulations
                            </h4>

                            <!-- Parallel Limits Configuration -->
                            <div style="
                                background: rgba(0, 0, 0, 0.2);
                                border: 1px solid rgba(255, 255, 255, 0.1);
                                border-radius: 6px;
                                padding: 12px;
                                margin-bottom: 16px;
                            ">
                                <h5 style="color: #fff; margin: 0 0 12px 0; font-size: 14px;">⏱️ Parallel Limits</h5>
                                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; font-size: 13px;">
                                    <div>
                                        <label style="color: #9ca3af; display: block; margin-bottom: 4px;">Every 5 min</label>
                                        <input id="limit-5min" type="number" min="0" max="10" value="1" style="
                                            background: rgba(0, 0, 0, 0.3);
                                            border: 1px solid rgba(255, 255, 255, 0.2);
                                            border-radius: 4px;
                                            color: #fff;
                                            padding: 6px 8px;
                                            width: 100%;
                                        " />
                                    </div>
                                    <div>
                                        <label style="color: #9ca3af; display: block; margin-bottom: 4px;">Every 15 min</label>
                                        <input id="limit-15min" type="number" min="0" max="10" value="1" style="
                                            background: rgba(0, 0, 0, 0.3);
                                            border: 1px solid rgba(255, 255, 255, 0.2);
                                            border-radius: 4px;
                                            color: #fff;
                                            padding: 6px 8px;
                                            width: 100%;
                                        " />
                                    </div>
                                    <div>
                                        <label style="color: #9ca3af; display: block; margin-bottom: 4px;">Every 1 hour</label>
                                        <input id="limit-1hour" type="number" min="0" max="10" value="1" style="
                                            background: rgba(0, 0, 0, 0.3);
                                            border: 1px solid rgba(255, 255, 255, 0.2);
                                            border-radius: 4px;
                                            color: #fff;
                                            padding: 6px 8px;
                                            width: 100%;
                                        " />
                                    </div>
                                </div>
                            </div>

                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                                <h5 style="color: #fff; margin: 0; font-size: 16px;">🎯 Active Sessions</h5>
                                <button id="add-simulation-btn" style="
                                    background: linear-gradient(135deg, #f59e0b, #d97706);
                                    border: none;
                                    border-radius: 6px;
                                    color: #fff;
                                    padding: 6px 12px;
                                    cursor: pointer;
                                    font-size: 12px;
                                    font-weight: 600;
                                    transition: all 0.2s ease;
                                ">+ New Simulation</button>
                            </div>

                            <div id="trading-simulations-list" style="
                                background: rgba(0, 0, 0, 0.2);
                                border: 1px solid rgba(255, 255, 255, 0.1);
                                border-radius: 8px;
                                padding: 12px;
                                max-height: 400px;
                                overflow-y: auto;
                            ">
                                <div style="text-align: center; color: #9ca3af; padding: 20px;">
                                    No trading simulations configured
                                </div>
                            </div>
                        </div>

                        <!-- Section Actions -->
                        <div style="
                            background: rgba(255, 255, 255, 0.05);
                            border: 1px solid rgba(255, 255, 255, 0.1);
                            border-radius: 8px;
                            padding: 16px;
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                        ">
                            <div style="color: #9ca3af; font-size: 14px;">
                                Last save: <span id="last-save-time" style="color: #fff;">-</span>
                            </div>
                            <div style="display: flex; gap: 12px;">
                                <button id="reset-config-btn" style="
                                    background: rgba(239, 68, 68, 0.2);
                                    border: 1px solid rgba(239, 68, 68, 0.3);
                                    border-radius: 6px;
                                    color: #ef4444;
                                    padding: 8px 16px;
                                    cursor: pointer;
                                    font-size: 12px;
                                    font-weight: 600;
                                ">🔄 Reset</button>
                                <button id="save-config-btn" style="
                                    background: linear-gradient(135deg, #10b981, #059669);
                                    border: none;
                                    border-radius: 6px;
                                    color: #fff;
                                    padding: 8px 16px;
                                    cursor: pointer;
                                    font-size: 12px;
                                    font-weight: 600;
                                ">💾 Save</button>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal pour les statistiques d'assets -->
    <div id="asset-stats-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content" style="max-width: 900px;">
            <div class="modal-header">
                <h2 style="color: #fff; margin: 0; display: flex; align-items: center; gap: 10px;">
                    📊 Asset Statistics
                </h2>
                <span class="close-btn" id="close-asset-stats-modal">&times;</span>
            </div>
            <div class="modal-body" style="max-height: 70vh; overflow-y: auto;">
                <div id="asset-stats-loading" style="text-align: center; padding: 40px; color: #9ca3af;">
                    <div style="font-size: 24px; margin-bottom: 10px;">⏳</div>
                    <div>Loading data...</div>
                </div>
                <div id="asset-stats-content" style="display: none;">
                    <div id="price-stats-content"></div>
                    <div id="technical-analysis-content"></div>
                    <div id="volume-stats-content"></div>
                    <div id="market-cap-stats-content"></div>
                    <div id="llm-summary-content"></div>
                    <div id="asset-chart-container" style="margin-top: 20px;">
                        <canvas id="asset-chart"></canvas>
                    </div>
                </div>
                <div id="asset-stats-error" style="display: none; text-align: center; padding: 40px; color: #ef4444;">
                    <div style="font-size: 24px; margin-bottom: 10px;">❌</div>
                    <div>Loading Error</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal pour le contexte mondial -->
    <div id="world-context-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content" style="max-width: 700px;">
            <div class="modal-header">
                <h2 style="color: #fff; margin: 0; display: flex; align-items: center; gap: 10px;">
                    🌍 World Context
                </h2>
                <span class="close-btn" id="close-world-context-modal">&times;</span>
            </div>
            <div class="modal-body" style="max-height: 70vh; overflow-y: auto;">
                <div id="world-context-loading" style="text-align: center; padding: 40px; color: #9ca3af;">
                    <div style="font-size: 24px; margin-bottom: 10px;">⏳</div>
                    <div>Loading world context...</div>
                </div>
                <div id="world-context-content" style="display: none;">
                    <!-- Last Updated -->
                    <div style="background: #1f2937; padding: 12px 15px; border-radius: 8px; margin-bottom: 15px; display: flex; justify-content: space-between; align-items: center;">
                        <div style="color: #9ca3af; font-size: 13px;">
                            <span style="margin-right: 8px;">🕐</span>Last Updated:
                        </div>
                        <div id="context-last-updated" style="color: #fff; font-weight: 600; font-size: 13px;">
                            Never updated
                        </div>
                    </div>

                    <!-- Summary -->
                    <div style="background: #1f2937; padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                        <h3 style="color: #fff; margin: 0 0 10px 0; font-size: 16px;">📝 Summary</h3>
                        <div id="world-context-summary" style="color: #d1d5db; line-height: 1.6;">Loading...</div>
                    </div>

                    <!-- Sentiment Score -->
                    <div style="background: #1f2937; padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                        <h3 style="color: #fff; margin: 0 0 10px 0; font-size: 16px;">📊 Sentiment Score</h3>
                        <div style="display: flex; align-items: center; gap: 15px;">
                            <div id="sentiment-score" style="color: #fff; font-size: 32px; font-weight: 700;">
                                N/A
                            </div>
                            <div style="color: #9ca3af; font-size: 13px;">
                                (-1.0 = Very Bearish, +1.0 = Very Bullish)
                            </div>
                        </div>
                    </div>

                    <!-- Key Themes -->
                    <div style="background: #1f2937; padding: 15px; border-radius: 8px;">
                        <h3 style="color: #fff; margin: 0 0 10px 0; font-size: 16px;">🔑 Key Themes</h3>
                        <div id="key-themes-container" style="color: #d1d5db;">
                            <div style="color: #9ca3af; font-style: italic;">No themes identified</div>
                        </div>
                    </div>
                </div>
                <div id="world-context-error" style="display: none; text-align: center; padding: 40px; color: #ef4444;">
                    <div style="font-size: 24px; margin-bottom: 10px;">❌</div>
                    <div>Error loading context</div>
                </div>
            </div>
        </div>
    </div>

    <!-- License Modal -->
    <div id="license-modal" style="display: none;"></div>

    <!-- Modal pour l'historique des trades -->
    <div id="trades-history-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content" style="max-width: 1200px; max-height: 90vh;">
            <div class="modal-header">
                <h3 class="modal-title">📊 History des Trades</h3>
                <button class="close-btn" id="close-trades-history-modal">&times;</button>
            </div>
            <div class="modal-body" style="padding: 24px; overflow-y: auto;">
                
                <!-- Filtres et statistiques -->
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; padding: 16px; background: rgba(0, 0, 0, 0.2); border-radius: 8px;">
                    <div>
                        <h4 style="color: #fff; margin: 0 0 8px 0;">Filtres</h4>
                        <div style="display: flex; gap: 12px; align-items: center;">
                            <select id="trades-asset-filter" style="background: rgba(0, 0, 0, 0.3); color: #fff; border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 4px; padding: 6px 12px;">
                                <option value="">Tous les actifs</option>
                            </select>
                            <select id="trades-type-filter" style="background: rgba(0, 0, 0, 0.3); color: #fff; border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 4px; padding: 6px 12px;">
                                <option value="">Tous les types</option>
                                <option value="BUY">Achats</option>
                                <option value="SELL">Ventes</option>
                            </select>
                        </div>
                    </div>
                    <div style="text-align: right;">
                        <div style="color: #9ca3af; font-size: 12px;">Total des trades</div>
                        <div id="trades-total-count" style="color: #fff; font-size: 20px; font-weight: 600;">0</div>
                    </div>
                </div>
                
                <!-- Trades list -->
                <div id="trades-list" style="background: rgba(0, 0, 0, 0.2); border-radius: 8px; min-height: 400px;">
                    <div style="text-align: center; color: #9ca3af; padding: 40px; font-size: 14px;">
                        Loading trades...
                    </div>
                </div>
                
            </div>
        </div>
    </div>

    <!-- Modal for adding simulation -->
    <div id="add-simulation-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content" style="max-width: 600px;">
            <div class="modal-header">
                <h3 style="color: #fff; margin: 0; display: flex; align-items: center; gap: 10px;">
                    🎯 Add Trading Simulation
                </h3>
                <span class="close-btn" id="close-add-simulation-modal">&times;</span>
            </div>
            <div class="modal-body" style="padding: 24px;">
                <form id="add-simulation-form">
                    <div style="margin-bottom: 16px;">
                        <label style="color: #fff; display: block; margin-bottom: 8px; font-weight: 600;">Wallet</label>
                        <select id="simulation-wallet-select" required style="
                            background: rgba(0, 0, 0, 0.3);
                            border: 1px solid rgba(255, 255, 255, 0.2);
                            border-radius: 6px;
                            color: #fff;
                            padding: 10px 12px;
                            width: 100%;
                            font-size: 14px;
                        ">
                            <option value="">Select a wallet...</option>
                        </select>
                    </div>

                    <div style="margin-bottom: 16px;">
                        <label style="color: #fff; display: block; margin-bottom: 8px; font-weight: 600;">Trading Frequency</label>
                        <select id="simulation-frequency-select" required style="
                            background: rgba(0, 0, 0, 0.3);
                            border: 1px solid rgba(255, 255, 255, 0.2);
                            border-radius: 6px;
                            color: #fff;
                            padding: 10px 12px;
                            width: 100%;
                            font-size: 14px;
                        ">
                            <option value="5">Every 5 minutes</option>
                            <option value="15">Every 15 minutes</option>
                            <option value="60">Every 1 hour</option>
                        </select>
                    </div>

                    <div style="margin-bottom: 16px;">
                        <label style="color: #fff; display: block; margin-bottom: 8px; font-weight: 600;">Strategy</label>
                        <select id="simulation-strategy-select" required style="
                            background: rgba(0, 0, 0, 0.3);
                            border: 1px solid rgba(255, 255, 255, 0.2);
                            border-radius: 6px;
                            color: #fff;
                            padding: 10px 12px;
                            width: 100%;
                            font-size: 14px;
                        ">
                            <option value="conservative">Conservative (Low risk)</option>
                            <option value="balanced">Balanced (Medium risk)</option>
                            <option value="aggressive">Aggressive (High risk)</option>
                        </select>
                    </div>

                    <div style="display: flex; gap: 12px; margin-top: 24px;">
                        <button type="button" id="cancel-simulation-btn" style="
                            background: rgba(239, 68, 68, 0.2);
                            border: 1px solid rgba(239, 68, 68, 0.3);
                            border-radius: 6px;
                            color: #ef4444;
                            padding: 10px 20px;
                            cursor: pointer;
                            font-size: 14px;
                            font-weight: 600;
                            flex: 1;
                        ">Cancel</button>
                        <button type="submit" style="
                            background: linear-gradient(135deg, #f59e0b, #d97706);
                            border: none;
                            border-radius: 6px;
                            color: #fff;
                            padding: 10px 20px;
                            cursor: pointer;
                            font-size: 14px;
                            font-weight: 600;
                            flex: 1;
                        ">Create Simulation</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="js/license.js"></script>
    <script src="js/federated-edge-preview.js"></script>
    <script type="module" src="js/main.js"></script>
</body>
</html>
